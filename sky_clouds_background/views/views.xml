<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="sky_clouds_background_layout" name="Bright Daytime Cloudscape" inherit_id="website.layout" priority="50">
        <!-- Add styles for sky background -->
        <xpath expr="//head" position="inside">
            <style type="text/css">
                <![CDATA[
                /* ===== SKY BACKGROUND IMAGE ===== */
                .sky-background {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background-image: url('/sky_clouds_background/static/description/background.jpg?ver=3') !important;
                    background-size: cover;
                    background-position: center;
                    background-repeat: no-repeat;
                    z-index: -3;
                    pointer-events: none;
                }

                /* ===== GLOSSY OVERLAY ===== */
                .glossy-overlay {
                    position: fixed;
                    top: 0;
                    left: 0;
                    width: 100%;
                    height: 100%;
                    background: linear-gradient(125deg, 
                        rgba(255,255,255,0.25) 0%, 
                        rgba(255,255,255,0.1) 30%, 
                        rgba(255,255,255,0.15) 70%, 
                        transparent 100%);
                    pointer-events: none;
                    z-index: 10;
                    mix-blend-mode: overlay;
                    backdrop-filter: blur(1px);
                }

                /* ===== CLOUDS ===== */
                .cloud {
                    position: fixed;
                    background-image: url('/sky_clouds_background/static/description/cloud.png');
                    background-size: contain;
                    background-repeat: no-repeat;
                    pointer-events: none;
                    z-index: -2;
                    opacity: 0.9;
                    will-change: transform;
                }

                .cloud-small {
                    width: 120px;
                    height: 60px;
                }
                .cloud-medium {
                    width: 180px;
                    height: 90px;
                }
                .cloud-large {
                    width: 240px;
                    height: 120px;
                }
                .cloud-xlarge {
                    width: 300px;
                    height: 150px;
                }

                /* ===== RAIN ANIMATION ===== */
                .rain-container {
                    position: fixed;
                    top: -10%;
                    left: 0;
                    width: 100%;
                    height: 120%;
                    pointer-events: none;
                    z-index: -1;
                    overflow: hidden;
                }

                .raindrop {
                    position: absolute;
                    width: 2px;
                    height: 25px;
                    background: linear-gradient(to bottom, 
                        rgba(200,230,255,0.9) 0%, 
                        rgba(160,200,230,0.8) 40%,
                        rgba(120,160,200,0.6) 100%);
                    border-radius: 0 0 4px 4px;
                    animation: rain linear infinite;
                    opacity: 0.5;
                    box-shadow: 0 0 6px rgba(255,255,255,0.4);
                }

                @keyframes rain {
                    0% {
                        transform: translateY(-10vh) translateX(0);
                        opacity: 0.7;
                    }
                    100% {
                        transform: translateY(110vh) translateX(15px);
                        opacity: 0.2;
                    }
                }

                /* Responsive adjustments */
                @media (max-width: 768px) {
                    .cloud-small { width: 80px; height: 40px; }
                    .cloud-medium { width: 120px; height: 60px; }
                    .cloud-large { width: 160px; height: 80px; }
                    .cloud-xlarge { width: 200px; height: 100px; }
                    
                    .raindrop {
                        height: 15px;
                        width: 1.5px;
                    }
                }

                /* Ensure content stays above background */
                #wrap {
                    position: relative;
                    z-index: 20;
                    background: transparent !important;
                }

                .navbar, header, o_main_navbar, o_menu_sections, o_menu_toggle {
                    position: relative;
                    z-index: 100 !important;
                }
                
                .sound-control {
                    position: fixed;
                    bottom: 20px;
                    right: 20px;
                    z-index: 1000;
                    background: rgba(0,0,0,0.6);
                    color: white;
                    border: none;
                    border-radius: 50%;
                    width: 40px;
                    height: 40px;
                    cursor: pointer;
                    font-size: 20px;
                    transition: all 0.3s ease;
                    backdrop-filter: blur(5px);
                }
                
                .sound-control:hover {
                    background: rgba(0,0,0,0.8);
                    transform: scale(1.1);
                }
                ]]>
            </style>
        </xpath>

        <!-- Add sky background and containers -->
        <xpath expr="//body" position="inside">
            <div class="sky-background"/>
            <div id="cloud-container"/>
            <div class="rain-container" id="rain-container"/>
            <div class="glossy-overlay"/>
            <audio id="rain-sound" loop="loop" preload="auto">
                <source src="/sky_clouds_background/static/description/rain.mp3" type="audio/mpeg"/>
                Your browser does not support the audio element.
            </audio>
            <button id="sound-control" class="sound-control" title="Toggle Rain Sound">🔊</button>
        </xpath>

        <!-- Include external JavaScript -->
        <xpath expr="//body" position="after">
            <script type="text/javascript" src="/sky_clouds_background/static/src/js/clouds.js"/>
        </xpath>
    </template>
</odoo>
